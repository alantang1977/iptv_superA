{
  "sources": [
    "https://gh.tryxd.cn/https://raw.githubusercontent.com/alantang1977/IPTV-AI/main/output/channels.m3u",
    "http://aktv.space/live.m3u"
  ],
  "tvbox": {
    "enable": true,
    "catchup": {
      "enable": true,
      "days": 7,
      "template": "playseek={utc:YmdHMS}-{utcend:YmdHMS}"
    },
    "epg": "https://epg.112114.xyz/pp.xml"
  },
  "performance": {
    "threads": 8,
    "timeout": 15
  },
  "filters": {
    "remove_duplicates": true,
    "min_duration": 10,
    "allowed_extensions": [".m3u8", ".flv", ".mp4"]
  }
}
